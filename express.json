{
  "aiostreams_direct": {
    "name": "AIOStreams Nightly (Direct)",
    "enabled": true,
    "languages": [
      "en"
    ],
    "base_url": "https://aiostreamsfortheweebs.midnightignite.me",
    "response_type": "json",
    "time_to_wait_between_each_request_ms": 300,
    "time_to_wait_on_too_many_request_ms": 5000,
    "movie": {
      "query": "/api/v1/search?type=movie&id={imdbId}&requiredFields=url&requiredFields=filename",
      "keywords": "{imdbId}"
    },
    "episode": {
      "query": "/api/v1/search?type=series&id={showImdbId}:{season}:{episode}&requiredFields=url&requiredFields=filename",
      "keywords": "{showImdbId}"
    },
    "anime": {
      "query": "/api/v1/search?type=series&id={showImdbId}:{season}:{episode}&requiredFields=url&requiredFields=filename",
      "keywords": "{showImdbId}"
    },
    "json_format": {
      "results": "data.results",
      "url": "url",
      "title": "filename",
      "size": "size",
      "playbackFileName": "filename",
      "playbackFileSize": "size",
      "host": "url",
      "host:ops": [
        {
          "name": "regex",
          "params": [
            "^https?://([^/:]+)"
          ]
        }
      ]
    }
  }
}
