{
  "aiostreams_direct": {
    "name": "AIOStreams Direct",
    "enabled": true,
    "languages": [
      "en"
    ],
    "base_url": "https://aiostreamsfortheweebsstable.midnightignite.me",
    "response_type": "json",
    "movie": {
      "query": "/api/v1/search?type=movie&id={imdbId}&format=true&requiredFields=url",
      "keywords": "{imdbId}"
    },
    "episode": {
      "query": "/api/v1/search?type=series&id={showImdbId}:{season}:{episode}&format=true&requiredFields=url",
      "keywords": "{showImdbId}"
    },
    "anime": {
      "query": "/api/v1/search?type=series&id={showImdbId}:{season}:{episode}&format=true&requiredFields=url",
      "keywords": "{showImdbId}"
    },
    "json_format": {
      "results": "data.results",
      "url": "url",
      "title": "filename",
      "size": "size",
      "host": "url",
      "host:ops": [
        {
          "name": "regex",
          "params": [
            "https?://([^/]+)"
          ]
        }
      ]
    }
  }
}
