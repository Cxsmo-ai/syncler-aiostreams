{
  "aiostreams": {
    "name": "AIOStreams",
    "enabled": true,
    "languages": [
      "en"
    ],
    "base_url": "https://aiostreamsfortheweebsstable.midnightignite.me",
    "response_type": "json",
    "movie": {
      "query": "/api/v1/search?type=movie&id={query}&format=true",
      "keywords": "{imdbId}"
    },
    "episode": {
      "query": "/api/v1/search?type=series&id={query}:{season}:{episode}&format=true",
      "keywords": "{showImdbId}"
    },
    "anime": {
      "query": "/api/v1/search?type=series&id={query}:{season}:{episode}&format=true",
      "keywords": "{showImdbId}"
    },
    "json_format": {
      "results": "data.results",
      "url": "url",
      "hash": "infoHash",
      "title": "name",
      "seeds": "seeders",
      "size": "size",
      "host": "url",
      "host:ops": [
        {
          "name": "regex",
          "params": [
            "https?://([^/]+)"
          ]
        }
      ],
      "playbackFileName": "filename",
      "playbackFileSize": "size"
    }
  }
}
