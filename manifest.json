{
  "name": "AioStreams",
  "id": "com.cxsmo.aiostreams",
  "version": 1,
  "url": "https://cxsmo-ai.github.io/syncler-aiostreams/express.json",
  "type": "express",
  "accounts": [
    {
      "alias": "aio",

      "branding": {
        "name": "AioStreams (ELF)",
        "website": "https://aiostreamsfortheweebsstable.midnightignite.me",
        "logo": "https://aiostreamsfortheweebsstable.midnightignite.me/logo.png"
      },

      "auth": {
        "type": "basic"
      },

      "verification": {
        "url": "https://aiostreamsfortheweebsstable.midnightignite.me/stremio/{managedAccounts.aio.username}/{managedAccounts.aio.password}/manifest.json",
        "method": "GET",
        "responseType": "json",

        "extract": {
          "username": {
            "type": "jsonpath",
            "value": "$.id"
          }
        }
      }
    }
  ]
}
