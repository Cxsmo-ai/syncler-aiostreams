{
  "name": "AIOStreams",
  "id": "com.cxsmo.syncler.aiostreams",
  "version": 1,
  "url": "https://cxsmo-ai.github.io/syncler-aiostreams/express.json",
  "type": "express",
  "accounts": [
    {
      "alias": "aio",
      "branding": {
        "name": "AIOStreams",
        "website": "https://aiostreamsfortheweebsstable.midnightignite.me",
        "logo": "https://aiostreamsfortheweebsstable.midnightignite.me/logo.png"
      },
      "auth": {
        "type": "basic",
        "allowedDomains": [
          "midnightignite.me"
        ],
        "inject": {
          "headers": {
            "Authorization": "Basic {managedAccounts.aio.basicToken}"
          }
        }
      },
      "verification": {
        "url": "https://aiostreamsfortheweebsstable.midnightignite.me/api/v1/user",
        "method": "GET",
        "responseType": "json",
        "extract": {
          "username": {
            "type": "jsonpath",
            "value": "$.detail"
          }
        }
      }
    }
  ]
}
