{
  "name": "AIOStreams for Syncler (GitHub v2)",
  "id": "com.cxsmo.syncler.aiostreams.github.direct.v2",
  "version": 1784141457,
  "url": "https://raw.githubusercontent.com/Cxsmo-ai/syncler-aiostreams/main/express.github.json",
  "type": "express",
  "accounts": [
    {
      "alias": "aio",
      "branding": {
        "name": "Midnight's AIOStreams Nightly",
        "website": "https://midnightignite.me",
        "logo": "https://aiostreamsfortheweebs.midnightignite.me/logo.png"
      },
      "auth": {
        "type": "basic",
        "allowedDomains": [
          "aiostreamsfortheweebs.midnightignite.me"
        ],
        "inject": {
          "headers": {
            "Authorization": "Basic {managedAccounts.aio.basicToken}"
          }
        }
      },
      "verification": {
        "url": "https://aiostreamsfortheweebs.midnightignite.me/api/v1/user",
        "method": "GET",
        "responseType": "json",
        "extract": {
          "username": {
            "type": "jsonpath",
            "value": "$.data.userData.uuid"
          }
        }
      }
    }
  ]
}
